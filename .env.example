# Medusa Backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_YOUR_MEDUSA_PUBLISHABLE_KEY_HERE

# Stripe
NEXT_PUBLIC_STRIPE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# Future .NET API
NEXT_PUBLIC_DOTNET_API_URL=http://localhost:5000

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# CMS on-demand revalidation — must match VITE_REVALIDATE_SECRET in backend-medusa/.env
# Server-side only (NO NEXT_PUBLIC_ prefix). Use a strong unique value in production.
REVALIDATE_SECRET=your-strong-revalidate-secret-here
